<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_page_bg"
    tools:context=".ProfileActivity">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_profile_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/settings_header_text" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingEnd="44dp"
            android:text="@string/profile_title"
            android:textColor="@color/settings_header_text"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 主内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="84dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="48dp"
            android:paddingEnd="20dp"
            android:paddingBottom="40dp">

            <!-- 头像区域 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <!-- 头像外圈装饰环 -->
                <View
                    android:id="@+id/avatarRing"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_profile_avatar_ring" />

                <!-- 头像图片 -->
                <ImageView
                    android:id="@+id/ivUserAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:contentDescription="用户头像"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_avatar_placeholder" />

                <!-- 上传中遮罩 -->
                <FrameLayout
                    android:id="@+id/avatarUploadOverlay"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_profile_avatar_overlay"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/white" />

                </FrameLayout>

                <!-- 点击选择头像的提示图标 -->
                <ImageView
                    android:id="@+id/ivAvatarEditHint"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="-6dp"
                    android:background="@drawable/bg_profile_avatar_edit_badge"
                    android:contentDescription="点击更换头像"
                    android:padding="5dp"
                    android:src="@drawable/ic_camera"
                    app:tint="@color/white" />

            </FrameLayout>

            <!-- 用户昵称 -->
            <TextView
                android:id="@+id/tvNickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textColor="@color/dashboard_title"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="小明同学" />

            <!-- 编辑资料按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfile"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/nav_selected"
                android:text="@string/profile_edit_button"
                android:textColor="@color/dashboard_title"
                android:textSize="13sp"
                app:cornerRadius="20dp" />

            <!-- 个人信息项列表 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:background="@drawable/bg_profile_item"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- 用户名 -->
                <LinearLayout
                    android:id="@+id/itemUsername"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/profile_label_username"
                        android:textColor="@color/dashboard_subtitle"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dashboard_title"
                        android:textSize="15sp"
                        tools:text="zhangsan" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/side_menu_stroke" />

                <!-- 账号ID -->
                <LinearLayout
                    android:id="@+id/itemUserId"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/profile_label_user_id"
                        android:textColor="@color/dashboard_subtitle"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvUserId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dashboard_muted"
                        android:textSize="15sp"
                        tools:text="ID: 10001" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
